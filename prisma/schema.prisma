generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  state             Json               @default("{}")
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// Phase 43.5: one-time invite codes, generated by the owner from the Admin
// panel. A used code keeps its row (usedAt/usedBy) as an audit trail — and so
// the signup door stays locked once any invite has ever been created.
model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  usedBy    String?
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  name      String?
  createdAt DateTime @default(now())
}
